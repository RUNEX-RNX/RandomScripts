    buyAllButton.BackgroundColor3 = Color3.fromRGB(0, 150, 100)
    buyAllButton.AutoButtonColor = false
    buyAllButton.Position = UDim2.new(0.65, 0, 0.65, 0)
    buyAllButton.Size = UDim2.new(0, 70, 0, 20)
    buyAllButton.Parent = exampleProductFrame

    local buyCorner = Instance.new("UICorner")
    buyCorner.CornerRadius = UDim.new(0, 4)
    buyCorner.Parent = buyAllButton

    -- ========== ЭФФЕКТЫ НАВЕДЕНИЯ ==========
    local function createHoverEffect(button, hoverColor)
        local originalColor = button.BackgroundColor3
        local tweenInfo = TweenInfo.new(0.15)
        button.MouseEnter:Connect(function()
            TweenService:Create(button, tweenInfo, {
                BackgroundColor3 = hoverColor
            }):Play()
        end)
        button.MouseLeave:Connect(function()
            TweenService:Create(button, tweenInfo, {
                BackgroundColor3 = originalColor
            }):Play()
        end)
    end

    createHoverEffect(copyButton, Color3.fromRGB(60, 60, 80))
    createHoverEffect(buyAllButton, Color3.fromRGB(0, 180, 120))

    -- ========== ЗАГРУЗКА ПРОДУКТОВ ==========
    task.spawn(function()
        local success, products = pcall(function()
            return MarketplaceService:GetDeveloperProductsAsync()
        end)

        if not success then
            warn("Failed to fetch developer products:", products)
            return
        end

        for _, productInfo in pairs(products:GetCurrentPage()) do
            local productFrame = exampleProductFrame:Clone()
            productFrame.Visible = true
            productFrame.Parent = scrollingFrame

            productFrame.NameLabel.Text = "📦 " .. productInfo.Name
            productFrame.IDLabel.Text = "🆔 " .. tostring(productInfo.ProductId)
            productFrame.DescLabel.Text = "📝 " .. productInfo.Description
            productFrame.PriceLabel.Text = "💰 " .. tostring(productInfo.PriceInRobux) .. " Robux"

            local productHoverBg = productFrame.HoverBg
            productFrame.Click.MouseEnter:Connect(function()
                TweenService:Create(productHoverBg, TweenInfo.new(0.2), {
                    BackgroundTransparency = 0.7
                }):Play()
            end)

            productFrame.Click.MouseLeave:Connect(function()
                TweenService:Create(productHoverBg, TweenInfo.new(0.2), {
                    BackgroundTransparency = 1
                }):Play()
            end)

            productFrame.Click.MouseButton1Click:Connect(function()
                pcall(function()
                    MarketplaceService:SignalPromptProductPurchaseFinished(localPlayer.UserId, productInfo.ProductId, true)
                end)
            end)

            local productCopyButton = productFrame.CopyButton
            productCopyButton.MouseButton1Click:Connect(function()
                if setclipboard then
                    setclipboard(tostring(productInfo.ProductId))
                    local originalText = productCopyButton.Text
                    productCopyButton.Text = "✅ Copied!"
                    productCopyButton.BackgroundColor3 = Color3.fromRGB(50, 150, 50)
                    task.wait(1)
                    productCopyButton.Text = originalText
                    productCopyButton.BackgroundColor3 = Color3.fromRGB(40, 40, 60)
                end
            end)

            local productBuyAllButton = productFrame.BuyAllButton
            productBuyAllButton.MouseButton1Click:Connect(function()
                local originalText = productBuyAllButton.Text
                productBuyAllButton.Text = "⏳..."
                productBuyAllButton.BackgroundColor3 = Color3.fromRGB(200, 100, 0)
                
                pcall(function()
                    MarketplaceService:SignalPromptProductPurchaseFinished(localPlayer.UserId, productInfo.ProductId, true)
                end)
                
                productBuyAllButton.Text = "✅ Done!"
                productBuyAllButton.BackgroundColor3 = Color3.fromRGB(50, 150, 50)
                task.wait(1.5)
                productBuyAllButton.Text = originalText
                productBuyAllButton.BackgroundColor3 = Color3.fromRGB(0, 150, 100)
            end)
        end
    end)

    -- ========== ОБРАБОТЧИК ЗАКРЫТИЯ ==========
    closeBtn.MouseButton1Click:Connect(function()
        if isScriptActive then
            toggleScript()
        end
        mainGui:Destroy()
    end)

    -- ========== ПЕРЕТАСКИВАНИЕ ОКНА ==========
    local isDragging = false
    local dragStart
    local startPosition

    developerProductsFrame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            isDragging = true
            dragStart = input.Position
            startPosition = developerProductsFrame.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    isDragging = false
                end
            end)
        end
    end)

    developerProductsFrame.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            if isDragging then
                local delta = input.Position - dragStart
                developerProductsFrame.Position = UDim2.new(
                    startPosition.X.Scale,
                    startPosition.X.Offset + delta.X,
                    startPosition.Y.Scale,
                    startPosition.Y.Offset + delta.Y
                )
            end
        end
    end)

    -- ========== ФУНКЦИЯ ВКЛЮЧЕНИЯ/ВЫКЛЮЧЕНИЯ ==========
    local function toggleScript()
        isScriptActive = not isScriptActive

        if isScriptActive then
            developerProductsFrame.Visible = true
            toggleBtn.Text = "✅ Dev Products"
            toggleBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 75) -- ЗЕЛЁНЫЙ
            toggleBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
            toggleStroke.Color = Color3.fromRGB(0, 255, 100)
            toggleStroke.Transparency = 0.2
        else
            developerProductsFrame.Visible = false
            toggleBtn.Text = "📦 Dev Products"
            toggleBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50) -- КРАСНЫЙ
            toggleBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
            toggleStroke.Color = Color3.fromRGB(255, 100, 100)
            toggleStroke.Transparency = 0.3
        end
    end

    -- ========== ОБРАБОТЧИК ТОГГЛ КНОПКИ ==========
    toggleBtn.MouseButton1Click:Connect(toggleScript)

    -- Эффекты наведения для кнопки-тоггла
    toggleBtn.MouseEnter:Connect(function()
        if isScriptActive then
            toggleBtn.BackgroundColor3 = Color3.fromRGB(0, 180, 90)
        else
            toggleBtn.BackgroundColor3 = Color3.fromRGB(100, 100, 100)
        end
    end)

    toggleBtn.MouseLeave:Connect(function()
        if isScriptActive then
            toggleBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 75)
        else
            toggleBtn.BackgroundColor3 = Color3.fromRGB(80, 80, 80)
        end
    end)
end

-- ========== ЗАПУСК ==========
createGUI()

